---
import { pricing } from '../../data/data';
---

<section id="tarifs" class="py-20 lg:py-28" style="background-color: var(--color-surface);">
  <div class="max-w-5xl mx-auto px-6">
    <div class="text-center mb-14">
      <div class="section-label fade-up" style="display: inline-flex;">Tarifs transparents</div>
      <h2 class="text-3xl lg:text-4xl mb-4 fade-up fade-up-delay-1" style="color: var(--color-text);">
        Des tarifs clairs, sans surprise
      </h2>
      <p class="text-base max-w-lg mx-auto fade-up fade-up-delay-2" style="color: var(--color-text-muted);">
        Premier contact par téléphone, puis bilan comportemental à domicile avant de démarrer tout programme.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      {pricing.map((category, ci) => (
        <div
          class={`rounded-2xl p-6 fade-up fade-up-delay-${ci + 1}`}
          style="background-color: var(--color-bg); border: 1px solid var(--color-border);"
        >
          <h3
            class="text-sm font-semibold uppercase tracking-wide mb-5 pb-3"
            style="color: var(--color-primary); border-bottom: 1px solid var(--color-border); font-family: var(--font-body);"
          >
            {category.category}
          </h3>
          <ul class="space-y-4">
            {category.items.map((item) => (
              <li class="flex items-start justify-between gap-3">
                <div class="flex-1">
                  <div class="text-sm font-medium" style="color: var(--color-text);">{item.name}</div>
                  {item.note && (
                    <div class="text-xs mt-0.5" style="color: var(--color-text-muted);">{item.note}</div>
                  )}
                </div>
                <div
                  class="text-sm font-bold flex-shrink-0"
                  style="color: var(--color-accent);"
                >
                  {item.price}
                </div>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div
      class="mt-8 p-5 rounded-2xl flex items-start gap-4 fade-up"
      style="background-color: var(--color-surface-alt); border: 1px solid rgba(45,90,27,0.2);"
    >
      <div
        class="w-8 h-8 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5"
        style="background-color: var(--color-primary);"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/>
          <path d="M12 16v-4"/>
          <path d="M12 8h.01"/>
        </svg>
      </div>
      <div>
        <p class="text-sm font-semibold mb-1" style="color: var(--color-text);">Adhésion Dog Harmonie Académie</p>
        <p class="text-sm" style="color: var(--color-text-muted);">
          Incluse à vie dans tous les forfaits : accès aux ressources pédagogiques, exercices et suivi de progression en ligne.
        </p>
      </div>
    </div>
  </div>
</section>
