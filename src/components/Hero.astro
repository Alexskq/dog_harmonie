---
import { site } from '../../data/data';
---

<section
  id="hero"
  class="relative min-h-screen flex items-center pt-16 overflow-hidden"
>
  <div
    class="absolute inset-0"
    style="background: linear-gradient(135deg, #E8F0E0 0%, #F2EBD9 50%, #FAFAF7 100%);"
  ></div>

  <div
    class="absolute top-20 right-0 w-[45vw] max-w-xl h-[70vh] rounded-l-3xl overflow-hidden hidden lg:block"
    style="box-shadow: -20px 20px 60px rgba(45, 90, 27, 0.15);"
  >
    <img
      src="/photos/hero.jpg"
      alt="Éducateur canin Dog Harmonie"
      class="w-full h-full object-cover"
      loading="eager"
    />
    <div
      class="absolute inset-0"
      style="background: linear-gradient(to right, rgba(232, 240, 224, 0.3) 0%, transparent 40%);"
    ></div>
  </div>

  <div class="absolute bottom-0 left-0 right-0 h-32 pointer-events-none" style="background: linear-gradient(to bottom, transparent, var(--color-bg));"></div>

  <div class="relative max-w-6xl mx-auto px-6 py-20 lg:py-32 w-full">
    <div class="max-w-xl">
      <div class="section-label fade-up">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor">
          <circle cx="12" cy="12" r="5"/>
        </svg>
        Métropole Valenciennoise
      </div>

      <h1
        class="text-4xl sm:text-5xl lg:text-6xl leading-tight mb-6 fade-up fade-up-delay-1"
        style="color: var(--color-text);"
      >
        Apprenez à vivre en{" "}
        <span style="color: var(--color-primary);">harmonie</span>{" "}
        avec votre chien
      </h1>

      <p
        class="text-lg leading-relaxed mb-6 fade-up fade-up-delay-2"
        style="color: var(--color-text-muted); max-width: 480px;"
      >
        {site.description}
      </p>

      <div class="relative block lg:hidden mb-8 rounded-2xl overflow-hidden fade-up fade-up-delay-3" style="aspect-ratio: 4/3; box-shadow: 0 12px 40px rgba(45, 90, 27, 0.18);">
        <img
          src="/photos/hero.jpg"
          alt="Éducateur canin Dog Harmonie"
          class="w-full h-full object-cover"
          loading="eager"
        />
        <div class="absolute inset-0 pointer-events-none" style="background: linear-gradient(to bottom, transparent 60%, rgba(232,240,224,0.4) 100%);"></div>
      </div>

      <div class="flex flex-wrap gap-4 mb-12 fade-up fade-up-delay-4">
        <a href="#contact" class="btn-primary">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M8 2v4"/>
            <path d="M16 2v4"/>
            <rect width="18" height="18" x="3" y="4" rx="2"/>
            <path d="M3 10h18"/>
          </svg>
          Prendre rendez-vous
        </a>
        <a href="#services" class="btn-secondary">
          Découvrir les services
        </a>
      </div>

      <div class="flex flex-wrap gap-6 fade-up fade-up-delay-5">
        {[
          { label: "Méthodes positives", icon: "heart" },
          { label: "Bilan offert", icon: "gift" },
          { label: "Résultats durables", icon: "check" },
        ].map(({ label, icon }) => (
          <div class="flex items-center gap-2">
            <div
              class="w-7 h-7 rounded-full flex items-center justify-center flex-shrink-0"
              style="background-color: var(--color-surface-alt);"
            >
              {icon === "heart" && (
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/>
                </svg>
              )}
              {icon === "gift" && (
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 12v10H4V12"/>
                  <path d="M2 7h20v5H2z"/>
                  <path d="M12 22V7"/>
                  <path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/>
                  <path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/>
                </svg>
              )}
              {icon === "check" && (
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 6 9 17l-5-5"/>
                </svg>
              )}
            </div>
            <span class="text-sm font-medium" style="color: var(--color-text);">{label}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
