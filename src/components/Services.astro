---
import { services } from '../../data/data';
---

<section id="services" class="py-20 lg:py-28" style="background-color: var(--color-bg);">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-14">
      <div class="section-label fade-up" style="display: inline-flex;">Nos services</div>
      <h2 class="text-3xl lg:text-4xl mb-4 fade-up fade-up-delay-1" style="color: var(--color-text);">
        Un accompagnement adapté à chaque chien
      </h2>
      <p class="text-base max-w-xl mx-auto fade-up fade-up-delay-2" style="color: var(--color-text-muted);">
        De l'éducation du chiot aux troubles du comportement, en passant par les activités sportives : trouvez le programme fait pour vous.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {services.map((service, i) => (
        <article
          class={`card-service fade-up fade-up-delay-${Math.min(i + 1, 5)}`}
        >
          <div class="relative h-48 overflow-hidden">
            <img
              src={service.image}
              alt={service.title}
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
            />
            <div
              class="absolute inset-0"
              style="background: linear-gradient(to top, rgba(26,36,16,0.5) 0%, transparent 60%);"
            ></div>
            <div
              class="absolute bottom-3 left-3 text-xs font-semibold px-3 py-1 rounded-full"
              style="background: rgba(250,250,247,0.95); color: var(--color-primary);"
            >
              {service.price}
            </div>
          </div>

          <div class="p-5">
            <p class="text-xs font-medium mb-1" style="color: var(--color-text-muted);">{service.subtitle}</p>
            <h3 class="text-lg font-semibold mb-2" style="font-family: var(--font-heading); color: var(--color-text);">
              {service.title}
            </h3>
            <p class="text-sm leading-relaxed mb-4" style="color: var(--color-text-muted);">
              {service.description}
            </p>
            <ul class="space-y-1.5">
              {service.details.map((detail) => (
                <li class="flex items-start gap-2 text-xs" style="color: var(--color-text-muted);">
                  <svg class="flex-shrink-0 mt-0.5" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20 6 9 17l-5-5"/>
                  </svg>
                  {detail}
                </li>
              ))}
            </ul>
          </div>
        </article>
      ))}
    </div>

    <div class="text-center mt-10 fade-up">
      <a href="#contact" class="btn-primary">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.5 19.79 19.79 0 0 1 1.61 4.9 2 2 0 0 1 3.6 2.69h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 10.09a16 16 0 0 0 6 6l.72-.72a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 17.42z"/>
        </svg>
        Réserver un bilan comportemental
      </a>
    </div>
  </div>
</section>
