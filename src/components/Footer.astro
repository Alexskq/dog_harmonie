---
import { site, services } from '../../data/data';
const year = new Date().getFullYear();
---

<footer style="background-color: var(--color-text); color: rgba(255,255,255,0.7);">
  <div class="max-w-6xl mx-auto px-6 py-14">
    <div class="grid md:grid-cols-3 gap-10 mb-10">
      <div>
        <div class="mb-4">
          <div class="w-16 h-16 rounded-full overflow-hidden" style="border: 2px solid rgba(255,255,255,0.2);">
            <img
              src="/photos/logo.png"
              alt="Dog Harmonie"
              class="w-full h-full object-cover object-top"
            />
          </div>
        </div>
        <p class="text-sm leading-relaxed mb-5" style="color: rgba(255,255,255,0.6);">
          {site.tagline}
        </p>
        <div class="flex gap-3">
          <a
            href={site.social.instagram}
            target="_blank"
            rel="noopener noreferrer"
            class="w-9 h-9 rounded-full flex items-center justify-center transition-colors"
            style="background-color: rgba(255,255,255,0.1);"
            aria-label="Instagram"
          >
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect width="20" height="20" x="2" y="2" rx="5" ry="5"/>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
              <line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/>
            </svg>
          </a>
          <a
            href={site.social.facebook}
            target="_blank"
            rel="noopener noreferrer"
            class="w-9 h-9 rounded-full flex items-center justify-center transition-colors"
            style="background-color: rgba(255,255,255,0.1);"
            aria-label="Facebook"
          >
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
            </svg>
          </a>
        </div>
      </div>

      <div>
        <h4 class="text-white text-sm font-semibold mb-4 uppercase tracking-wide">Services</h4>
        <ul class="space-y-2">
          {services.map((s) => (
            <li>
              <a
                href="#services"
                class="text-sm transition-colors hover:text-white"
                style="color: rgba(255,255,255,0.6);"
              >
                {s.title}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="text-white text-sm font-semibold mb-4 uppercase tracking-wide">Contact</h4>
        <ul class="space-y-3 text-sm" style="color: rgba(255,255,255,0.6);">
          <li>
            <a href={"tel:" + site.phone.replace(/\s/g, "")} class="hover:text-white transition-colors">
              {site.phone}
            </a>
          </li>
          <li>
            <a href={"mailto:" + site.email} class="hover:text-white transition-colors">
              {site.email}
            </a>
          </li>
          <li>{site.location}</li>
          <li class="text-xs" style="color: rgba(255,255,255,0.4);">SIRET : {site.siret}</li>
        </ul>
      </div>
    </div>

    <div
      class="pt-6 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs"
      style="border-top: 1px solid rgba(255,255,255,0.1); color: rgba(255,255,255,0.4);"
    >
      <span>© {year} Dog Harmonie. Tous droits réservés.</span>
      <span>Educateur canin certifie · Metropole Valenciennoise</span>
    </div>
  </div>
</footer>
