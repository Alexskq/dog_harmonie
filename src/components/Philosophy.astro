---
---

<section id="philosophie" class="py-20 lg:py-28" style="background-color: var(--color-surface);">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <div>
        <div class="section-label fade-up">Notre philosophie</div>
        <h2 class="text-3xl lg:text-4xl leading-snug mb-6 fade-up fade-up-delay-1" style="color: var(--color-text);">
          Écouter, respecter, et satisfaire les besoins de votre chien
        </h2>
        <p class="text-base leading-relaxed mb-6 fade-up fade-up-delay-2" style="color: var(--color-text-muted);">
          Dog Harmonie, c'est avant tout une relation. Pas une domination, pas une soumission, mais une communication bienveillante entre vous et votre chien, basée sur la confiance et le plaisir d'apprendre ensemble.
        </p>
        <p class="text-base leading-relaxed mb-8 fade-up fade-up-delay-3" style="color: var(--color-text-muted);">
          Grâce aux méthodes positives et au conditionnement au clicker, votre chien comprend ce que vous attendez de lui et il <em>veut</em> vous faire plaisir. Les résultats sont durables parce qu'ils sont fondés sur la motivation, pas la peur.
        </p>

        <div class="grid sm:grid-cols-3 gap-4 fade-up fade-up-delay-4">
          {[
            { number: "100%", label: "Méthodes positives" },
            { number: "2 mois", label: "Dès le premier âge" },
            { number: "59880", label: "Saint-Saulve & alentours" },
          ].map(({ number, label }) => (
            <div
              class="text-center p-4 rounded-2xl"
              style="background-color: var(--color-bg);"
            >
              <div class="text-2xl font-bold mb-1" style="font-family: var(--font-heading); color: var(--color-primary);">
                {number}
              </div>
              <div class="text-xs font-medium" style="color: var(--color-text-muted);">{label}</div>
            </div>
          ))}
        </div>
      </div>

      <div class="relative fade-up fade-up-delay-2">
        <div
          class="absolute -top-4 -left-4 w-full h-full rounded-3xl"
          style="background-color: var(--color-surface-alt); z-index: 0;"
        ></div>
        <div class="relative rounded-3xl overflow-hidden" style="z-index: 1; aspect-ratio: 4/3;">
          <img
            src="/photos/coaching.jpg"
            alt="Séance d'éducation canine bienveillante"
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>

        <div
          class="absolute -bottom-6 -right-6 rounded-2xl p-4 flex items-center gap-3"
          style="background-color: var(--color-bg); box-shadow: 0 8px 30px rgba(0,0,0,0.1); z-index: 2; min-width: 180px;"
        >
          <div
            class="w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0"
            style="background-color: var(--color-surface-alt);"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5z"/>
            </svg>
          </div>
          <div>
            <div class="text-sm font-semibold" style="color: var(--color-text);">5 étoiles</div>
            <div class="text-xs" style="color: var(--color-text-muted);">sur Google & Facebook</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
